# --- Paths ---
SDL_PATH=./akash-deploy.yaml
ACCOUNTS_PATH=./accounts.json
LOG_FILE=./logs/akash-bidding.log

# --- Akash Console managed-wallet API ---
AKASH_API_BASE=https://console-api.akash.network
# Chain REST node — bid polling reads from here (console-api /v1/bids returns []).
AKASH_RPC_BASE=https://rpc.akt.dev
# Single-account probe key (only used by scripts/probe.js)
AKASH_API_KEY=
# Optional single-account proxy for probe (e.g. http://user:pass@host:port)
AKASH_PROXY=

# --- Deployment / lease economics ---
DEPOSIT_USD=5
MIN_BALANCE_USD=5

# Price ceiling in USD per hour (preferred). Daemon converts to uact/block
# using averageBlockTime=6.098s and 1 USD = 1,000,000 uact (Console anchor).
# Example: 1.00 USD/hr ≈ 1694 uact/block. Inspect bid prices on Akash Console
# to calibrate. Leave MAX_UACT_PER_BLOCK blank when MAX_USD_PER_HOUR is set.
MAX_USD_PER_HOUR=1.00

# Override only if you need to think in raw chain units. Leave 0 / unset to
# let MAX_USD_PER_HOUR drive the cap.
MAX_UACT_PER_BLOCK=

# Substring blacklist match is case-insensitive. Beware "a10" would match "a100".
GPU_BLACKLIST=a100,pro6000se,h100

# --- Timings ---
# Tuned for GPU-scarce environments where we want maximum no-bid cycle
# throughput per account. Cycle math at these values (no-bid path):
#   POST + owner resolve   ≈ 3-7s
#   BID_WAIT_MS poll       ≤ 45s (terminates early on first bid)
#   close + release        ≈ 2-5s
#   RETRY sleep            15-30s
#   total                  ≈ 65-90s per no-bid cycle
# On lease success: LEASE_HOLD_MS dormant (1h) — see note below.
BID_WAIT_MS=45000
BID_POLL_INTERVAL_MS=5000
# Post-lease cooldown. At 1h, an account holds one GPU at a time (1h cooldown
# overlaps with the 24h group lock → practical 1:1 GPU per account). Lower
# this only if you want a single account to aggressively grab MULTIPLE GPUs
# in parallel — each lease costs $5 escrow upfront, so budget accordingly.
LEASE_HOLD_MS=3600000
RETRY_MIN_MS=15000
RETRY_MAX_MS=30000
REQUEST_TIMEOUT_MS=30000

# Safety: mark account exhausted after this many consecutive no-match cycles.
NO_MATCH_EXHAUST_THRESHOLD=9999

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- MySQL (group/account/deployment state) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=akashbid
MYSQL_PASSWORD=
MYSQL_DATABASE=akash_bidding

# --- Group management ---
GROUP_LOCK_HOURS=24
# Short TTL on the pre-POST pending lock. Daemon locks a group before POSTing
# the deployment so the SDL ships with the real GROUP_NAME baked in (no PUT,
# single ReplicaSet on the provider). If the daemon crashes between lock and
# lease, the sweeper auto-releases at this TTL. Must cover BID_WAIT_MS plus
# lease attempts with margin. Allowed range: 2..60 minutes.
GROUP_LOCK_PENDING_MINUTES=10
SWEEP_INTERVAL_MS=300000
PUT_NAG_INTERVAL_MS=1800000

# Only used by `npm run db:seed-groups`. Operator-only one-shot — daemon does
# not read it. You can also pass `--dir=/path` to the seed script instead.
# RPOW2_DATA_DIR=/path/to/rpow2/data

# --- Admin HTTP API (hard-bound to 127.0.0.1, no auth) ---
# The bind address is NOT configurable — it is loopback-only by design.
# Use an SSH tunnel for remote admin.
API_PORT=8088
